# ── Telegram ──────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=

# Manager's chat ID for new lead notifications
MANAGER_CHAT_ID=

# ── Google ────────────────────────────────────────────────
# Manager's email address for PDF delivery via Apps Script
MANAGER_EMAIL=

# Google Sheet ID (from URL: /spreadsheets/d/<SPREADSHEET_ID>/edit)
SPREADSHEET_ID=

# Path to Google service account JSON key file
GOOGLE_CREDENTIALS_PATH=./credentials.json
