# ── Telegram ──────────────────────────────────────────────
# Токен бота від @BotFather
BOT_TOKEN=

# Chat ID менеджера, куди надсилати сповіщення про нові заявки
MANAGER_CHAT_ID=

# ── Google ────────────────────────────────────────────────
# Email менеджера, куди Apps Script надсилає PDF
MANAGER_EMAIL=

# ID Google-таблиці (з URL: /spreadsheets/d/<SPREADSHEET_ID>/edit)
SPREADSHEET_ID=

# Шлях до JSON з ключами сервісного акаунта Google
GOOGLE_CREDENTIALS_PATH=./credentials.json
